APP_BASE_URL=http://localhost:8501
DATABASE_PATH=leads.db

# Required for the protected operator area at ?admin=1.
ADMIN_PASSWORD=change-me

# Destination for public Lead Rescue follow-up requests and fallback owner notifications.
# The editable business profile owner_email is used first when present.
OWNER_EMAIL=owner@example.com
FROM_EMAIL=Lead Rescue AI <noreply@example.com>

# Email options: disabled, resend, smtp
EMAIL_PROVIDER=disabled

# Resend option
RESEND_API_KEY=

# SMTP option
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
